# Must match the URL the browser uses to reach your API (same origin you use for axios & sockets).
# Production example: VITE_API_URL=https://api.yourdomain.com
VITE_API_URL=http://localhost:5000

# Show the yellow test/staging banner. Set to 'true' on staging, omit or 'false' for production.
VITE_SHOW_TEST_BANNER=true
