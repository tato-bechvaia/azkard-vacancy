generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYER
  CANDIDATE
}

enum JobRegime {
  REMOTE
  HYBRID
  FULL_TIME
}

enum JobStatus {
  HIRING
  CLOSED
}

enum Experience {
  NONE
  ONE_TO_THREE
  THREE_TO_FIVE
  FIVE_PLUS
}

enum ApplicationMethod {
  CV_ONLY
  FORM_ONLY
  BOTH
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  SHORTLISTED
  REJECTED
  HIRED
}

model User {
  id               Int               @id @default(autoincrement())
  email            String            @unique
  passwordHash     String
  role             Role
  phone            String?
  isVerified       Boolean           @default(false)
  isAdmin          Boolean           @default(false)
  verifyCode       String?
  createdAt        DateTime          @default(now())
  employerProfile  EmployerProfile?
  candidateProfile CandidateProfile?
  notifications Notification[]
}

model EmployerProfile {
  id          Int          @id @default(autoincrement())
  userId      Int          @unique
  companyName String
  description String?
  website     String?
  logoUrl     String?
  avatarUrl   String?
  user        User         @relation(fields: [userId], references: [id])
  jobs        Job[]
  companyBoxes CompanyBox[]
}

model CompanyBox {
  id          Int           @id @default(autoincrement())
  companyId   Int
  title       String
  description String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  employer    EmployerProfile @relation(fields: [companyId], references: [id])
  submissions CVSubmission[]
}

model CVSubmission {
  id             Int        @id @default(autoincrement())
  companyBoxId   Int
  candidateName  String
  candidateEmail String
  cvUrl          String
  message        String?
  submittedAt    DateTime   @default(now())
  companyBox     CompanyBox @relation(fields: [companyBoxId], references: [id])
}

model CandidateProfile {
  id           Int           @id @default(autoincrement())
  userId       Int           @unique
  firstName    String
  lastName     String
  headline     String?
  location     String?
  cvUrl        String?
  avatarUrl    String?
  user         User          @relation(fields: [userId], references: [id])
  applications Application[]
}

model Job {
  id                Int               @id @default(autoincrement())
  title             String
  description       String
  location          String?
  salaryMin         Int
  salaryMax         Int?
  currency          String            @default("GEL")
  jobRegime         JobRegime
  jobPeriod         String?
  experience        Experience        @default(NONE)
  applicationMethod ApplicationMethod @default(CV_ONLY)
  status            JobStatus         @default(HIRING)
  views             Int               @default(0)
  createdAt         DateTime          @default(now())
  expiresAt         DateTime?
  isForStudents     Boolean           @default(false)
  isInternship      Boolean           @default(false)
  employerProfileId Int
  employer          EmployerProfile   @relation(fields: [employerProfileId], references: [id])
  applications      Application[]
  category          JobCategory       @default(OTHER)
  isPremium         Boolean           @default(false)
  premiumBadgeLabel String?
  highlightColor    String?
  featuredUntil     DateTime?
}

model Application {
  id                 Int               @id @default(autoincrement())
  jobId              Int
  candidateProfileId Int
  status             ApplicationStatus @default(PENDING)
  coverLetter        String?
  cvUrl              String?
  formData           Json?
  appliedAt          DateTime          @default(now())
  job                Job               @relation(fields: [jobId], references: [id])
  candidate          CandidateProfile  @relation(fields: [candidateProfileId], references: [id])
}

enum JobCategory {
  IT
  SALES
  MARKETING
  FINANCE
  DESIGN
  MANAGEMENT
  LOGISTICS
  HEALTHCARE
  EDUCATION
  HOSPITALITY
  OTHER
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

