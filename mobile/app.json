{
  "expo": {
    "name": "Azkard",
    "slug": "azkard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.azkard.vacancy"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0f"
      },
      "package": "com.azkard.vacancy"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-image-picker",
      "expo-document-picker",
      "expo-asset"
    ]
  }
}
